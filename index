<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Valencia Basket - Histórico Pamesa</title>
    <style>
        :root {
            --valencia-orange: #FF6600;
            --pamesa-red: #D32F2F;
            --pamesa-white: #FFFFFF;
        }

        body {
            font-family: 'Arial Black', sans-serif;
            margin: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            min-height: 100vh;
            background-color: var(--pamesa-white);
            /* Fondo de azulejos retro */
            background-image: 
                linear-gradient(45deg, var(--pamesa-red) 25%, transparent 25%), 
                linear-gradient(-45deg, var(--pamesa-red) 25%, transparent 25%),
                linear-gradient(45deg, transparent 75%, var(--pamesa-red) 75%),
                linear-gradient(-45deg, transparent 75%, var(--pamesa-red) 75%);
            background-size: 40px 40px;
        }

        .header {
            background: var(--valencia-orange);
            color: white;
            width: 100%;
            text-align: center;
            padding: 15px 0;
            border-bottom: 5px solid black;
            text-transform: uppercase;
        }

        .main-content {
            width: 90%;
            max-width: 500px;
            margin-top: 20px;
            text-align: center;
        }

        select {
            width: 100%;
            padding: 15px;
            font-size: 1.1rem;
            border: 3px solid black;
            border-radius: 0;
            background: white;
            font-weight: bold;
            margin-bottom: 30px;
        }

        /* El Azulejo Pamesa */
        #tile {
            display: none;
            background: white;
            border: 10px solid var(--valencia-orange);
            padding: 40px 20px;
            box-shadow: 10px 10px 0px rgba(0,0,0,0.8);
            position: relative;
        }

        #tile::before {
            content: "";
            position: absolute;
            top: 5px; left: 5px;
            width: 15px; height: 15px;
            background: rgba(0,0,0,0.1);
            border-radius: 50%;
        }

        .apellido { color: var(--pamesa-red); font-size: 2.5rem; margin: 0; text-transform: uppercase; }
        .cifra { color: var(--valencia-orange); font-size: 5.5rem; margin: 10px 0; line-height: 1; }
        .disciplina { font-size: 1.2rem; background: #333; color: white; padding: 5px 15px; display: inline-block; }

        @keyframes pop {
            0% { transform: scale(0.8); opacity: 0; }
            100% { transform: scale(1); opacity: 1; }
        }
    </style>
</head>
<body>

<div class="header">
    <h2>Líderes Históricos</h2>
</div>

<div class="main-content">
    <select id="selector" onchange="actualizar()">
        <option value="">-- SELECCIONA LEYENDA --</option>
        <optgroup label="PUNTOS">
            <option value="1">Dubljevic (4.358)</option>
            <option value="2">Rafa Martínez (3.625)</option>
            <option value="3">Hopkins (3.125)</option>
        </optgroup>
        <optgroup label="REBOTES">
            <option value="4">Dubljevic (2.074)</option>
            <option value="5">Hopkins (1.407)</option>
        </optgroup>
        <optgroup label="ASISTENCIAS">
            <option value="6">Salva Díez (890)</option>
            <option value="7">Nacho Rodilla (680)</option>
        </optgroup>
    </select>

    <div id="tile">
        <p class="apellido" id="txtApellido"></p>
        <p class="cifra" id="txtCifra"></p>
        <div class="disciplina" id="txtDisc"></div>
    </div>
</div>

<script>
    const datos = {
        "1": ["Dubljevic", "4.358", "Puntos"],
        "2": ["Martínez", "3.625", "Puntos"],
        "3": ["Hopkins", "3.125", "Puntos"],
        "4": ["Dubljevic", "2.074", "Rebotes"],
        "5": ["Hopkins", "1.407", "Rebotes"],
        "6": ["Díez", "890", "Asistencias"],
        "7": ["Rodilla", "680", "Asistencias"]
    };

    function actualizar() {
        const val = document.getElementById('selector').value;
        const tile = document.getElementById('tile');
        
        if (val) {
            document.getElementById('txtApellido').innerText = datos[val][0];
            document.getElementById('txtCifra').innerText = datos[val][1];
            document.getElementById('txtDisc').innerText = datos[val][2];
            tile.style.display = 'block';
            tile.style.animation = 'pop 0.3s ease-out forwards';
        } else {
            tile.style.display = 'none';
        }
    }
</script>

</body>
</html>
